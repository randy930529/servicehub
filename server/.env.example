# MongoDB connection string (inline connection — no Docker).
# Local mongod:
NEXT_MONGODB_URI=mongodb://127.0.0.1:27017/servicehub
# Or MongoDB Atlas:
# NEXT_MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/servicehub?retryWrites=true&w=majority

# Pagination defaults for GET /api/services (optional — these are the defaults).
# NEXT_DEFAULT_PAGE=1
# NEXT_DEFAULT_LIMIT=10
# NEXT_MAX_LIMIT=100
