# MongoDB connection string (inline connection — no Docker).
# Local mongod:
NEXT_MONGODB_URI=mongodb://127.0.0.1:27017/servicehub
# Or MongoDB Atlas:
# NEXT_MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/servicehub?retryWrites=true&w=majority

# Secret used to sign access JWTs (HS256). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
NEXT_JWT_SECRET=replace-me-with-a-long-random-secret

# Token lifetimes (optional — these are the defaults).
# NEXT_JWT_ACCESS_TTL_SECONDS=900
# NEXT_REFRESH_TOKEN_TTL_DAYS=30

# Pagination defaults for GET /api/services (optional — these are the defaults).
# NEXT_DEFAULT_PAGE=1
# NEXT_DEFAULT_LIMIT=10
# NEXT_MAX_LIMIT=100
